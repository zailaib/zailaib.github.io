---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '谬误侦探 · Fallacy Detective',
    subtitle: '识别逻辑谬误 · 训练批判性思维',
    desc: '化身逻辑侦探，破解四个经典谬误案件：赌徒谬误（硬币赌局）、假两难（找到第三条路）、稻草人论证（识破扭曲的观点）、诉诸人身（区分攻击与反驳）。在黑色电影风格的互动故事中，锻炼你的思维敏锐度。',
    play: '开始调查 🔍',
  },
  en: {
    title: 'Fallacy Detective',
    subtitle: 'Spot Logical Fallacies · Train Critical Thinking',
    desc: 'Become a logic detective and solve four classic fallacy cases: Gambler\'s Fallacy (coin betting game), False Dilemma (find the third way), Strawman (spot the distortion), and Ad Hominem (separate attack from argument). Sharpen your thinking in a noir-style interactive story.',
    play: 'Investigate 🔍',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/fallacy-detective/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe
        src="/games/fallacy-detective/"
        title={c.title}
        allowfullscreen
        scrolling="no"
      ></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 900px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); font-family: 'Noto Serif SC', Georgia, serif; letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 560px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(212,176,96,0.12); color: #d4b060; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(212,176,96,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(212,176,96,0.2); border-color: rgba(212,176,96,0.6); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #121215; }
  .game-frame iframe { width: 100%; height: 620px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 480px; } }
</style>
