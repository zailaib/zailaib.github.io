---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '宇宙速度 · Cosmic Velocity 3D',
    subtitle: '轨道力学交互演示 — 第一/第二/第三宇宙速度',
    desc: '调节火箭速度，实时观察轨道从坠落→圆轨道→椭圆→逃逸的变化。直观理解第一宇宙速度（7.9 km/s 圆轨道）、第二宇宙速度（11.2 km/s 逃逸地球）、第三宇宙速度（16.7 km/s 逃逸太阳系）。可切换太阳系视角。',
    play: '进入轨道 🚀',
  },
  en: {
    title: 'Cosmic Velocity · Orbital Mechanics 3D',
    subtitle: 'Interactive demo of the three cosmic velocities',
    desc: 'Adjust rocket speed and watch the orbit change in real-time: suborbital → circular → elliptical → escape. Understand the 1st cosmic velocity (7.9 km/s), 2nd (11.2 km/s), and 3rd (16.7 km/s). Toggle to solar system view.',
    play: 'Launch 🚀',
  },
};
---
<GamePage
  game="cosmic-velocity"
  accentColor="#ff8844"
  accentBg="rgba(255,130,60,0.12)"
  accentBorder="rgba(255,130,60,0.3)"
  accentBgHover="rgba(255,130,60,0.2)"
  accentBorderHover="rgba(255,130,60,0.5)"
  frameBg="#0a0a14"
  frameHeight={680}
  frameHeightMobile={520}
  content={content}
  paper={{
    zh: { title:'An Introduction to the Mathematics and Methods of Astrodynamics (Revised Edition)', author:'Battin, R.H.', journal:'AIAA Education Series', year:'1999', doi:'', desc:'MIT 航天动力学经典教材。本书的数学方法直接用于 Apollo 8 月球导航——作者 Battin 正是 Apollo 导航系统的首席科学家。涵盖二体问题、Lambert 问题、轨道确定与行星际转移。' },
    en: { title:'An Introduction to the Mathematics and Methods of Astrodynamics (Revised Edition)', author:'Battin, R.H.', journal:'AIAA Education Series', year:'1999', doi:'', desc:'The definitive MIT astrodynamics textbook. The mathematical methods in this book were directly used for Apollo 8 lunar navigation — Battin was the lead scientist behind the Apollo guidance system. Covers two-body problems, Lambert\'s problem, orbit determination, and interplanetary transfer.' },
  }}
/>
