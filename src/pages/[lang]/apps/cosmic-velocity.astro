---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '宇宙速度 · Cosmic Velocity 3D',
    subtitle: '轨道力学交互演示 — 第一/第二/第三宇宙速度',
    desc: '调节火箭速度，实时观察轨道从坠落→圆轨道→椭圆→逃逸的变化。直观理解第一宇宙速度（7.9 km/s 圆轨道）、第二宇宙速度（11.2 km/s 逃逸地球）、第三宇宙速度（16.7 km/s 逃逸太阳系）。可切换太阳系视角。',
    play: '进入轨道 🚀',
  },
  en: {
    title: 'Cosmic Velocity · Orbital Mechanics 3D',
    subtitle: 'Interactive demo of the three cosmic velocities',
    desc: 'Adjust rocket speed and watch the orbit change in real-time: suborbital → circular → elliptical → escape. Understand the 1st cosmic velocity (7.9 km/s), 2nd (11.2 km/s), and 3rd (16.7 km/s). Toggle to solar system view.',
    play: 'Launch 🚀',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/cosmic-velocity/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/cosmic-velocity/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(255,130,60,0.12); color: #ff8844; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(255,130,60,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(255,130,60,0.2); border-color: rgba(255,130,60,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #000011; }
  .game-frame iframe { width: 100%; height: 580px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 440px; } }
</style>
