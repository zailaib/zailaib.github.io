---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: 'λ Lisp Club · Scheme REPL',
    subtitle: '浏览器中的 BiwaScheme 交互式编程环境',
    desc: '在浏览器中直接运行 Scheme 代码。支持 car/cdr/cons、lambda 匿名函数、递归、map/filter 高阶函数。右侧内置 20+ 代码片段，点击即可载入或直接执行。支持 ↑↓ 浏览输入历史。Scheme 是 Lisp 方言，极简语法——括号即 AST。',
    play: '进入 REPL λ',
  },
  en: {
    title: 'λ Lisp Club · Scheme REPL',
    subtitle: 'BiwaScheme interactive programming in the browser',
    desc: 'Run Scheme code directly in your browser. Supports list ops, lambda, recursion, map/filter, and more. 20+ built-in snippet examples on the right — click to load or execute. Arrow keys for history. Scheme is a Lisp dialect: minimal syntax, maximum expressiveness.',
    play: 'Open REPL λ',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/lisp-club/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/lisp-club/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; font-family: 'JetBrains Mono', monospace; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(88,166,255,0.12); color: #58a6ff; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(88,166,255,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(88,166,255,0.2); border-color: rgba(88,166,255,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #0d1117; }
  .game-frame iframe { width: 100%; height: 560px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 440px; } }
</style>
