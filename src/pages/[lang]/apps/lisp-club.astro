---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: 'λ Lisp Club · Scheme REPL',
    subtitle: '浏览器中的 BiwaScheme 交互式编程环境',
    desc: '在浏览器中直接运行 Scheme 代码。支持 car/cdr/cons、lambda 匿名函数、递归、map/filter 高阶函数。右侧内置 20+ 代码片段，点击即可载入或直接执行。Scheme 是 Lisp 方言，极简语法——括号即 AST。',
    play: '进入 REPL λ',
  },
  en: {
    title: 'λ Lisp Club · Scheme REPL',
    subtitle: 'BiwaScheme interactive programming in the browser',
    desc: 'Run Scheme code directly in your browser. Supports list ops, lambda, recursion, map/filter, and more. 20+ built-in snippet examples on the right — click to load or execute. Scheme is a Lisp dialect: minimal syntax, maximum expressiveness.',
    play: 'Open REPL λ',
  },
};
---
<GamePage
  game="lisp-club"
  accentColor="#58a6ff"
  accentBg="rgba(88,166,255,0.12)"
  accentBorder="rgba(88,166,255,0.3)"
  accentBgHover="rgba(88,166,255,0.2)"
  accentBorderHover="rgba(88,166,255,0.5)"
  frameBg="#0d1117"
  frameHeight={660}
  frameHeightMobile={500}
  content={content}
/>
