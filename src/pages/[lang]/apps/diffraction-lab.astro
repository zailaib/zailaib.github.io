---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '光的衍射实验室 · Diffraction Lab',
    subtitle: '杨氏双缝实验 · Three.js 3D 交互演示',
    desc: '在三维空间中观察光的衍射现象。调节狭缝宽度、间距和波长，实时观察干涉条纹的变化。粒子波动从光源穿过狭缝抵达屏幕——直观感受惠更斯原理和波的叠加。支持单缝衍射与双缝干涉两种模式。',
    play: '进入实验室 🔬',
  },
  en: {
    title: 'Diffraction Lab · Light Wave Optics',
    subtitle: "Young's Double-Slit · Interactive 3D Demo",
    desc: 'Observe light diffraction in 3D space. Adjust slit width, separation, and wavelength to see the interference pattern change in real-time. Wave particles flow from source through slits to screen — an intuitive visualization of Huygens\' principle and wave superposition.',
    play: 'Enter Lab 🔬',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/diffraction-lab/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/diffraction-lab/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 960px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(100,150,255,0.12); color: #8ab4f8; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(100,150,255,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(100,150,255,0.2); border-color: rgba(100,150,255,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #000; }
  .game-frame iframe { width: 100%; height: 560px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 400px; } }
</style>
