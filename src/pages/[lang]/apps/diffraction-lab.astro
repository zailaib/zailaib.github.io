---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '光的衍射实验室 · Diffraction Lab',
    subtitle: '杨氏双缝实验 · Three.js 3D 交互演示',
    desc: '在三维空间中观察光的衍射现象。调节狭缝宽度、间距和波长，实时观察干涉条纹的变化。粒子波动从光源穿过狭缝抵达屏幕——直观感受惠更斯原理和波的叠加。支持单缝衍射与双缝干涉两种模式。',
    play: '进入实验室 🔬',
  },
  en: {
    title: 'Diffraction Lab · Light Wave Optics',
    subtitle: "Young's Double-Slit · Interactive 3D Demo",
    desc: "Observe light diffraction in 3D space. Adjust slit width, separation, and wavelength to see the interference pattern change in real-time. Wave particles flow from source through slits to screen — an intuitive visualization of Huygens' principle and wave superposition.",
    play: 'Enter Lab 🔬',
  },
};
---
<GamePage
  game="diffraction-lab"
  accentColor="#8ab4f8"
  accentBg="rgba(100,150,255,0.12)"
  accentBorder="rgba(100,150,255,0.3)"
  accentBgHover="rgba(100,150,255,0.2)"
  accentBorderHover="rgba(100,150,255,0.5)"
  frameBg="#0a0a14"
  frameHeight={680}
  frameHeightMobile={520}
  content={content}
  paper={{
    zh: { title:'Principles of Optics (7th Edition) — Chapter 8: Elements of the Theory of Diffraction', author:'Born, M. & Wolf, E.', journal:'Cambridge University Press', year:'1999', doi:'', desc:'光学领域的"圣经"。第 8 章从麦克斯韦方程组出发，完整推导 Kirchhoff 衍射理论、Fraunhofer 远场近似、单缝/双缝/光栅衍射的数学表达式——正是本 App 屏幕干涉条纹的理论基础。' },
    en: { title:'Principles of Optics (7th Edition) — Chapter 8: Elements of the Theory of Diffraction', author:'Born, M. & Wolf, E.', journal:'Cambridge University Press', year:'1999', doi:'', desc:'The "bible" of optics. Chapter 8 rigorously derives Kirchhoff\'s diffraction theory, Fraunhofer far-field approximation, and the mathematical expressions for single-slit, double-slit, and grating diffraction from Maxwell\'s equations — the theoretical foundation of this app\'s interference patterns.' },
  }}
/>
