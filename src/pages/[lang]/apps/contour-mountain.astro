---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '等高线山脉 · Contour Mountain 3D',
    subtitle: '地理地形学演示 — 等高线 + 水位面 + 海拔分色',
    desc: '程序生成的山脉地形 + 实时等高线（Marching Squares 算法）。拖动水位面，水面与山体的交线就是等高线——直观理解地形图的原理。支持调节等高线间距、线框模式。海拔颜色：绿（低）→黄→棕→白（峰）。',
    play: '进入地形 🏔️',
  },
  en: {
    title: 'Contour Mountain · 3D Topographic Demo',
    subtitle: 'Geography & Topography — Contour lines, water level, elevation coloring',
    desc: 'Procedural mountain terrain with real-time contour lines (Marching Squares). Drag the water level — the shoreline IS a contour line. Understand how topographic maps work. Adjustable contour interval and wireframe mode.',
    play: 'Explore 🏔️',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/contour-mountain/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/contour-mountain/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(120,200,100,0.12); color: #8c8; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(120,200,100,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(120,200,100,0.2); border-color: rgba(120,200,100,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #1a1a2e; }
  .game-frame iframe { width: 100%; height: 560px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 420px; } }
</style>
