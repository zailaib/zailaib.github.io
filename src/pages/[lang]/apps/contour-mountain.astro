---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '等高线山脉 · Contour Mountain 3D',
    subtitle: '地理地形学演示  等高线 + 水位面 + 海拔分色',
    desc: '程序生成的山脉地形 + 实时等高线（Marching Squares 算法）。拖动水位面，水面与山体的交线就是等高线——直观理解地形图的原理。支持调节等高线间距、线框模式。海拔颜色：绿（低）→黄→棕→白（峰）。',
    play: '进入地形 🏔️',
  },
  en: {
    title: 'Contour Mountain · 3D Topographic Demo',
    subtitle: 'Geography & Topography  Contour lines, water level, elevation coloring',
    desc: 'Procedural mountain terrain with real-time contour lines (Marching Squares). Drag the water level  the shoreline IS a contour line. Understand how topographic maps work. Adjustable contour interval and wireframe mode.',
    play: 'Explore 🏔️',
  },
};
---
<GamePage
  game="contour-mountain"
  accentColor="#8c8"
  accentBg="rgba(120,200,100,0.12)"
  accentBorder="rgba(120,200,100,0.3)"
  accentBgHover="rgba(120,200,100,0.2)"
  accentBorderHover="rgba(120,200,100,0.5)"
  frameBg="#0a0a14"
  frameHeight={700}
  frameHeightMobile={540}
  content={content}
  paper={{
    zh: { title:'Marching Cubes: A High Resolution 3D Surface Construction Algorithm', author:'Lorensen, W.E. & Cline, H.E.', journal:'SIGGRAPH Computer Graphics', year:'1987', doi:'10.1145/37401.37422', desc:'被引 20,000+ 次的经典论文。Marching Squares（2D 等高线）即源于此文的 3D 算法 Marching Cubes，现代医学影像、气象可视化、游戏地形的基础。' },
    en: { title:'Marching Cubes: A High Resolution 3D Surface Construction Algorithm', author:'Lorensen, W.E. & Cline, H.E.', journal:'SIGGRAPH Computer Graphics', year:'1987', doi:'10.1145/37401.37422', desc:'Cited 20,000+ times. The 2D Marching Squares contour algorithm originates from this paper\'s 3D Marching Cubes  the foundation of modern medical imaging, weather visualization, and game terrain rendering.' },
  }}
/>
