---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '抓光点 ✨',
    subtitle: '反应力小游戏 · 像逗猫棒一样好玩',
    desc: '屏幕上有一个跳动的金色光点，点击抓住它！连击得分翻倍，光点会越来越快。30 秒内看看你能抓多少？',
    play: '全屏畅玩 ↗',
    back: '返回应用',
  },
  en: {
    title: 'Catch the Dot ✨',
    subtitle: 'Reflex Game · Chase the Glow',
    desc: 'A golden dot bounces around the screen — click to catch it! Combos multiply your score, and the dot gets faster. How many can you catch in 30 seconds?',
    play: 'Play Fullscreen ↗',
    back: 'Back to Apps',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/catch-the-dot/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe
        src="/games/catch-the-dot/"
        title={c.title}
        allowfullscreen
        scrolling="no"
      ></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }
  .game-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .game-header h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
  }
  .subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-tertiary);
    margin-bottom: var(--spacing-md);
  }
  .desc {
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto var(--spacing-xl);
    line-height: var(--line-height-relaxed);
  }
  .play-btn {
    display: inline-block;
    padding: 12px 36px;
    background: linear-gradient(135deg, #ff9800, #f57c00);
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 1px;
    transition: all 0.3s;
    box-shadow: 0 4px 20px rgba(255,152,0,0.35);
  }
  .play-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 30px rgba(255,152,0,0.5);
  }
  .game-frame {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    background: #0a0a0f;
  }
  .game-frame iframe {
    width: 100%;
    height: 520px;
    border: none;
    display: block;
  }
  @media (max-width: 768px) {
    .game-page { padding: var(--spacing-md); }
    .game-frame iframe { height: 420px; }
  }
</style>
