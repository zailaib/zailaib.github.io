---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '逻辑哲学论 · Tractatus',
    subtitle: '维特根斯坦的哲学游戏 · 揭示事实的结构',
    desc: '拖拽连接几何对象，发现"事态"（Sachverhalte）。每找到一个事实，就揭示一条《逻辑哲学论》命题。世界是事实的总和，而非事物的总和——在游戏中体验维特根斯坦的核心洞见：对象只有在事态中才有意义。',
    play: '开始探索 →',
    back: '返回应用',
  },
  en: {
    title: 'Tractatus Logico-Philosophicus',
    subtitle: "Wittgenstein's Philosophy Game · Reveal the Structure of Facts",
    desc: 'Drag between geometric objects to discover "states of affairs." Each fact reveals a proposition from the Tractatus. The world is the totality of facts, not of things — experience Wittgenstein\'s core insight: objects only have meaning within states of affairs.',
    play: 'Enter →',
    back: 'Back to Apps',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/tractatus/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe
        src="/games/tractatus/"
        title={c.title}
        allowfullscreen
        scrolling="no"
      ></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }
  .game-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .game-header h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
    font-family: 'Courier New', monospace;
    letter-spacing: 1px;
  }
  .subtitle {
    font-size: var(--font-size-md);
    color: var(--color-text-tertiary);
    margin-bottom: var(--spacing-md);
  }
  .desc {
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--spacing-xl);
    line-height: var(--line-height-relaxed);
    font-size: 14px;
  }
  .play-btn {
    display: inline-block;
    padding: 12px 36px;
    background: none;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    border-radius: 2px;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 2px;
    font-family: 'Courier New', monospace;
    border: 1px solid rgba(255,255,255,0.3);
    transition: all 0.3s;
  }
  .play-btn:hover {
    border-color: rgba(255,255,255,0.7);
    color: #fff;
    background: rgba(255,255,255,0.05);
  }
  .game-frame {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    background: #0d0d0d;
  }
  .game-frame iframe {
    width: 100%;
    height: 540px;
    border: none;
    display: block;
  }
  @media (max-width: 768px) {
    .game-page { padding: var(--spacing-md); }
    .game-frame iframe { height: 420px; }
  }
</style>
