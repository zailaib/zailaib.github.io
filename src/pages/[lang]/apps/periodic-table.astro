---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '元素周期表 · Periodic Table 3D',
    subtitle: '118 个元素 · 点击查看电子排布 3D 模型',
    desc: '完整的元素周期表，点击任意元素即可在右侧看到 3D 玻尔原子模型。原子核 + 电子层（K/L/M/N/O/P/Q）+ 每层电子以不同颜色环绕运动。支持拖拽旋转和缩放，直观感受原子结构。',
    play: '打开周期表 ⚛️',
  },
  en: {
    title: 'Periodic Table · 3D Electron Shells',
    subtitle: '118 Elements · Click to View 3D Bohr Model',
    desc: 'Complete periodic table with 3D atom visualization. Click any element to see the Bohr model with nucleus and electron shells (K/L/M/N/O/P/Q). Electrons orbit in color-coded shells. Rotate and zoom for an intuitive understanding of atomic structure.',
    play: 'Open Table ⚛️',
  },
};
---
<GamePage
  game="periodic-table"
  accentColor="#8ab4f8"
  accentBg="rgba(138,180,248,0.12)"
  accentBorder="rgba(138,180,248,0.3)"
  accentBgHover="rgba(138,180,248,0.2)"
  accentBorderHover="rgba(138,180,248,0.5)"
  frameBg="#0a0a14"
  frameHeight={780}
  frameHeightMobile={580}
  content={content}
  paper={{
    zh: { title:'The Periodic Table: Its Story and Its Significance (2nd Edition)', author:'Scerri, E.', journal:'Oxford University Press', year:'2019', doi:'', desc:'周期表哲学与历史领域最权威著作。从门捷列夫到量子力学——解释电子排布如何决定元素在周期表中的位置、周期律的哲学意涵、以及超铀元素的发现竞赛。' },
    en: { title:'The Periodic Table: Its Story and Its Significance (2nd Edition)', author:'Scerri, E.', journal:'Oxford University Press', year:'2019', doi:'', desc:'The definitive work on the philosophy and history of the periodic table. From Mendeleev to quantum mechanics  explains how electron configurations determine element placement, the philosophical implications of the periodic law, and the race to discover transuranium elements.' },
  }}
/>
