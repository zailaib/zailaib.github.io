---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '元素周期表 · Periodic Table 3D',
    subtitle: '118 个元素 · 点击查看电子排布 3D 模型',
    desc: '完整的元素周期表，点击任意元素即可在右侧看到 3D 玻尔原子模型。原子核 + 电子层（K/L/M/N/O/P/Q）+ 每层电子以不同颜色环绕运动。支持拖拽旋转和缩放，直观感受原子结构。',
    play: '打开周期表 ⚛️',
  },
  en: {
    title: 'Periodic Table · 3D Electron Shells',
    subtitle: '118 Elements · Click to View 3D Bohr Model',
    desc: 'Complete periodic table with 3D atom visualization. Click any element to see the Bohr model with nucleus and electron shells (K/L/M/N/O/P/Q). Electrons orbit in color-coded shells. Rotate and zoom for an intuitive understanding of atomic structure.',
    play: 'Open Table ⚛️',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/periodic-table/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/periodic-table/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(138,180,248,0.12); color: #8ab4f8; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(138,180,248,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(138,180,248,0.2); border-color: rgba(138,180,248,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #0a0a12; }
  .game-frame iframe { width: 100%; height: 620px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 520px; } }
</style>
