---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const all = await getCollection('apps');
const apps = all
  .filter((a) => a.id.startsWith(lang))
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .map((a) => {
    const name = a.id.replace(/\.[^/.]+$/, '').split('/').pop();
    return { ...a.data, url: `/${lang}/apps/${name}` };
  });

const t = (zh: string, en: string) => (lang === 'en' ? en : zh);
const title = t('小游戏 & 应用', 'Mini Games & Apps');
const subtitle = t('拖拽、点击、探索——在游戏中发现思想', 'Drag, click, explore — discover ideas through play');
---
<BaseLayout title={title} currentSlug="" showMinimap={false}>
  <div class="apps-page">
    <header class="apps-header">
      <h1>{title}</h1>
      <p class="subtitle">{subtitle}</p>
    </header>
    <div class="apps-grid">
      {apps.map(app => (
        <a href={app.url} class="app-card">
          <div class="app-icon">🎮</div>
          <div class="app-info">
            <h3 class="app-title">{app.title}</h3>
            {app.description && <p class="app-desc">{app.description}</p>}
            {app.cta && <span class="app-cta">{app.cta}</span>}
          </div>
          <span class="app-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .apps-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-2xl) var(--spacing-lg);
  }
  .apps-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }
  .apps-header h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
  }
  .subtitle {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-md);
  }
  .apps-grid {
    display: grid;
    gap: var(--spacing-lg);
  }
  .app-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-normal);
    backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-shadow);
  }
  .app-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent-primary);
  }
  .app-icon {
    font-size: 36px;
    flex-shrink: 0;
  }
  .app-info {
    flex: 1;
    min-width: 0;
  }
  .app-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 6px 0;
  }
  .app-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0 0 8px 0;
    line-height: var(--line-height-relaxed);
  }
  .app-cta {
    display: inline-block;
    font-size: 12px;
    color: var(--color-accent-primary);
    border: 1px solid rgba(255,152,0,0.3);
    padding: 3px 12px;
    border-radius: 50px;
    letter-spacing: 1px;
  }
  .app-arrow {
    font-size: 22px;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .app-card:hover .app-arrow {
    transform: translateX(4px);
    color: var(--color-accent-primary);
  }
  @media (max-width: 768px) {
    .apps-page { padding: var(--spacing-lg); }
    .app-card { padding: var(--spacing-lg); gap: var(--spacing-md); }
    .app-icon { font-size: 28px; }
  }
</style>
