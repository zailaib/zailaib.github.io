---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '细胞分裂 · Cell Division 3D',
    subtitle: '有丝分裂全过程 — 间期→前期→中期→后期→末期→胞质分裂',
    desc: '交互式 3D 有丝分裂动画。拖拽时间轴或点击播放，观察染色体凝缩、核膜解体、赤道板排列、姐妹染色单体分离、核膜重建、细胞质分裂的全过程。4 对染色体（2n=8），含纺锤丝和中心体。',
    play: '进入观察 🔬',
  },
  en: {
    title: 'Cell Division · Mitosis 3D Animation',
    subtitle: 'Complete mitosis — Interphase → Prophase → Metaphase → Anaphase → Telophase → Cytokinesis',
    desc: 'Interactive 3D mitosis animation. Scrub the timeline or click play to observe chromosome condensation, nuclear envelope breakdown, metaphase plate alignment, sister chromatid separation, nuclear envelope reformation, and cytokinesis. 4 chromosome pairs (2n=8), spindle fibers and centrosomes included.',
    play: 'Explore 🔬',
  },
};
---
<GamePage
  game="cell-division"
  accentColor="#6af"
  accentBg="rgba(100,180,255,0.12)"
  accentBorder="rgba(100,180,255,0.3)"
  accentBgHover="rgba(100,180,255,0.2)"
  accentBorderHover="rgba(100,180,255,0.5)"
  frameBg="#0a0a14"
  frameHeight={720}
  frameHeightMobile={560}
  content={content}
/>
