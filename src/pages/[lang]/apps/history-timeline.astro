---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '历史时间轴 · 3D History Gantt',
    subtitle: '5500 年 · 五大文明轨道 · 一目了然的时空对比',
    desc: '横跨 3500 BCE 到 2025 CE，中国/欧洲/中东/印度/美洲五大文明轨道并排展示。每个朝代是一个 3D 进度条，重大事件是发光柱——拖拽时间轴，一眼看懂"唐朝时欧洲在经历什么"。悬停查看详情，快捷跳转到任意时代。',
    play: '浏览历史 📜',
  },
  en: {
    title: 'History Timeline · 3D Gantt Chart',
    subtitle: '5500 Years · 5 Civilizations · Compare Across Time',
    desc: 'From 3500 BCE to 2025 CE: China, Europe, Middle East, India, Americas laid out as parallel 3D Gantt tracks. Each dynasty is a bar, each key event is a pillar — scroll through time and instantly see what was happening across civilizations. Hover for details.',
    play: 'Explore 📜',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/history-timeline/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/history-timeline/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(200,160,120,0.12); color: #c8a878; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(200,160,120,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(200,160,120,0.2); border-color: rgba(200,160,120,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #0a0a12; }
  .game-frame iframe { width: 100%; height: 580px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 420px; } }
</style>
