---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '历史大道 · History Run',
    subtitle: '跑步穿越 5500 年 · 7 种载具 · 42 个历史事件收集',
    desc: '从公元前 3500 年的步行者开始，历经骑马、骑象、宝船航海、蒸汽火车、燃油汽车，一路跑到火箭时代。路边的金色事件球就是历史里程碑——跑过去自动收集，右侧弹出事件卡片。加速/减速/暂停，自由探索历史大道。',
    play: '开跑 🏃',
  },
  en: {
    title: 'History Run · Time-Travel Road Trip',
    subtitle: 'Run through 5500 years · 7 vehicles · 42 collectible events',
    desc: 'Start as a walker in 3500 BCE, ride horses, elephants, sail treasure ships, drive steam trains and vintage cars, all the way to rockets. Golden event orbs line the road — run through them to collect and reveal historical milestones on the side panel.',
    play: 'Run 🏃',
  },
};
---
<GamePage
  game="history-timeline"
  accentColor="#c8a878"
  accentBg="rgba(200,160,120,0.12)"
  accentBorder="rgba(200,160,120,0.3)"
  accentBgHover="rgba(200,160,120,0.2)"
  accentBorderHover="rgba(200,160,120,0.5)"
  frameBg="#0a0a14"
  frameHeight={720}
  frameHeightMobile={560}
  content={content}
  paper={{
    zh: { title:'The Human Web: A Bird\'s-Eye View of World History', author:'McNeill, J.R. & McNeill, W.H.', journal:'W.W. Norton & Company', year:'2003', doi:'', desc:'父子历史学家联袂——用"人类网络"框架串联 5000 年文明互动。从苏美尔到互联网，论证文明史本质是联系日益紧密的"网"。本书启发本 App 的"历史大道"互动叙事设计。' },
    en: { title:'The Human Web: A Bird\'s-Eye View of World History', author:'McNeill, J.R. & McNeill, W.H.', journal:'W.W. Norton & Company', year:'2003', doi:'', desc:'A father-son historian duo weaves 5,000 years of civilization into a single "human web" framework. From Sumer to the Internet, argues that the essence of world history is an ever-densifying network of connections — the conceptual inspiration behind this app\'s "History Run" interactive narrative.' },
  }}
/>
