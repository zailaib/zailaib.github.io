---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '地球气象 · Earth Weather 3D',
    subtitle: '洋流 · 大气环流 · 冷锋暖锋 — 气象学交互演示',
    desc: '3D 地球展示全球洋流系统（墨西哥湾暖流、黑潮、南极绕极流等）、大气环流（信风带、西风带）、以及冷锋与暖锋交汇形成降雨的过程。可单独开关各图层，切换夏/冬季观察季风方向变化。',
    play: '观察气象 🌍',
  },
  en: {
    title: 'Earth Weather · Climate Systems 3D',
    subtitle: 'Ocean Currents · Winds · Cold/Warm Fronts & Rain',
    desc: '3D globe showing major ocean currents (Gulf Stream, Kuroshio, Circumpolar), atmospheric circulation (trade winds, westerlies), and cold/warm front collision creating precipitation. Toggle layers and switch seasons.',
    play: 'Explore 🌍',
  },
};
---
<GamePage
  game="earth-weather"
  accentColor="#6af"
  accentBg="rgba(80,160,220,0.12)"
  accentBorder="rgba(80,160,220,0.3)"
  accentBgHover="rgba(80,160,220,0.2)"
  accentBorderHover="rgba(80,160,220,0.5)"
  frameBg="#0a0a14"
  frameHeight={700}
  frameHeightMobile={540}
  content={content}
  paper={{
    zh: { title:'The Changing Flow of Energy Through the Climate System', author:'Trenberth, K.E.', journal:'Cambridge University Press', year:'2022', doi:'10.1017/9781108979030', desc:'NCAR 首席科学家对全球能量流的权威综述。从太阳辐射、海洋热含量、大气环流到极端天气——系统解释洋流如何耦合大气输送热量，全球变暖如何改变这些流动。' },
    en: { title:'The Changing Flow of Energy Through the Climate System', author:'Trenberth, K.E.', journal:'Cambridge University Press', year:'2022', doi:'10.1017/9781108979030', desc:'Authoritative synthesis by NCAR\'s lead climate scientist. From solar radiation and ocean heat content to atmospheric circulation and extreme weather — systematically explains how ocean currents couple with the atmosphere to transport heat, and how global warming alters these flows.' },
  }}
/>
