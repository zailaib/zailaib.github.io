---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const content = {
  zh: {
    title: '细胞探索者 · Cell Explorer 3D',
    subtitle: '植物 · 动物 · 噬菌体 · 小球藻 — 四种细胞结构对比',
    desc: '在 3D 空间中观察四种生物结构：植物细胞（细胞壁+中央液泡+叶绿体）、动物细胞（中心体+溶酶体）、T4噬菌体（衣壳+尾鞘+尾丝）、小球藻（杯状叶绿体+淀粉核）。鼠标悬停查看细胞器详情。',
    play: '进入观察 🔬',
  },
  en: {
    title: 'Cell Explorer · 3D Cell Structures',
    subtitle: 'Plant · Animal · Bacteriophage · Chlorella — Compare 4 cell types',
    desc: 'Explore 3D cell models: Plant (cell wall + central vacuole + chloroplasts), Animal (centrioles + lysosomes), T4 Bacteriophage (capsid + tail sheath + fibers), Chlorella (cup-shaped chloroplast + pyrenoid). Hover to see organelle details.',
    play: 'Explore 🔬',
  },
} as const;

const c = content[lang as 'zh' | 'en'];
---
<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href="/games/cell-explorer/" target="_blank">{c.play}</a>
    </header>
    <div class="game-frame">
      <iframe src="/games/cell-explorer/" title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
  </div>
</BaseLayout>

<style>
  .game-page { max-width: 1000px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
  .game-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .game-header h1 { font-size: var(--font-size-3xl); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); letter-spacing: 2px; }
  .subtitle { font-size: var(--font-size-md); color: var(--color-text-tertiary); margin-bottom: var(--spacing-md); }
  .desc { color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--spacing-xl); line-height: var(--line-height-relaxed); font-size: 14px; }
  .play-btn { display: inline-block; padding: 12px 36px; background: rgba(100,200,150,0.12); color: #6c6; text-decoration: none; border-radius: 2px; font-weight: 600; font-size: 15px; letter-spacing: 2px; border: 1px solid rgba(100,200,150,0.3); transition: all 0.3s; }
  .play-btn:hover { background: rgba(100,200,150,0.2); border-color: rgba(100,200,150,0.5); }
  .game-frame { border-radius: 4px; overflow: hidden; box-shadow: 0 8px 40px rgba(0,0,0,0.5); background: #080814; }
  .game-frame iframe { width: 100%; height: 580px; border: none; display: block; }
  @media (max-width: 768px) { .game-page { padding: var(--spacing-md); } .game-frame iframe { height: 440px; } }
</style>
