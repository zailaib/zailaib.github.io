---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '细胞探索者 · Cell Explorer 3D',
    subtitle: '植物 · 动物 · 噬菌体 · 小球藻  四种细胞结构对比',
    desc: '在 3D 空间中观察四种生物结构：植物细胞（细胞壁+中央液泡+叶绿体）、动物细胞（中心体+溶酶体）、T4噬菌体（衣壳+尾鞘+尾丝）、小球藻（杯状叶绿体+淀粉核）。鼠标悬停查看细胞器详情。',
    play: '进入观察 🔬',
  },
  en: {
    title: 'Cell Explorer · 3D Cell Structures',
    subtitle: 'Plant · Animal · Bacteriophage · Chlorella  Compare 4 cell types',
    desc: 'Explore 3D cell models: Plant (cell wall + central vacuole + chloroplasts), Animal (centrioles + lysosomes), T4 Bacteriophage (capsid + tail sheath + fibers), Chlorella (cup-shaped chloroplast + pyrenoid). Hover to see organelle details.',
    play: 'Explore 🔬',
  },
};
---
<GamePage
  game="cell-explorer"
  accentColor="#6c6"
  accentBg="rgba(100,200,150,0.12)"
  accentBorder="rgba(100,200,150,0.3)"
  accentBgHover="rgba(100,200,150,0.2)"
  accentBorderHover="rgba(100,200,150,0.5)"
  frameBg="#0a0a14"
  frameHeight={720}
  frameHeightMobile={560}
  content={content}
  paper={{
    zh: { title:'Cellular Landscapes in Watercolor', author:'Goodsell, D.S.', journal:'J. Biocommunication', year:'2016', doi:'10.5210/jbc.v40i1.6627', desc:'用水彩手绘呈现细胞内部的分子景观——将 X 射线晶体学、冷冻电镜数据转化为可直观理解的细胞结构图，是分子可视化领域的里程碑工作。' },
    en: { title:'Cellular Landscapes in Watercolor', author:'Goodsell, D.S.', journal:'J. Biocommunication', year:'2016', doi:'10.5210/jbc.v40i1.6627', desc:'Hand-painted watercolor molecular landscapes of cell interiors  synthesizing X-ray crystallography, cryo-ET, and super-resolution microscopy data into intuitively understandable cellular scenes. A landmark in molecular visualization.' },
  }}
/>
