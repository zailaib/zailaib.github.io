---
import GamePage from '../../../components/GamePage.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const content = {
  zh: {
    title: '拆解老屋 · House Dismantle 3D',
    subtitle: '框选部件 → 按 1 拆解 → 按 1 组装 — 探索传统三间房的结构',
    desc: '一栋农村传统三间房：一层 2.8m，上半层墙 1.5m，屋顶最高 5.5m。鼠标拖拽旋转视角、Ctrl+拖拽框选部件、点击选中单个部件，按 1 键拆解选中的部件（含结构依赖），再次按 1 组装复原。',
    play: '进入拆解 🏠',
  },
  en: {
    title: 'House Dismantle · Traditional 3-Bay House',
    subtitle: 'Drag-select parts → press 1 to dismantle → press 1 to reassemble',
    desc: 'A traditional rural 3-bay house: ground floor 2.8m, upper half-story wall 1.5m, roof peak 5.5m. Drag to rotate view, Ctrl+drag to box-select parts, click to pick individual parts, press 1 to disassemble selected parts (with structural dependencies), press 1 again to reassemble.',
    play: 'Explore 🏠',
  },
};
---
<GamePage
  game="house-dismantle"
  accentColor="#b8754a"
  accentBg="rgba(180,120,80,0.12)"
  accentBorder="rgba(180,120,80,0.3)"
  accentBgHover="rgba(180,120,80,0.2)"
  accentBorderHover="rgba(180,120,80,0.5)"
  frameBg="#0a0a14"
  frameHeight={720}
  frameHeightMobile={560}
  content={content}
/>
