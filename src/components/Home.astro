---
import { t } from '../i18n/utils';

interface Props {
  latest: { title: string; url: string; date: Date; tags?: string }[];
  latestApps: { title: string; url: string; date?: Date; description?: string; cta?: string; ctaUrl?: string }[];
  lang: string;
}

const { latest, latestApps, lang } = Astro.props;
---

<main class="home-content" data-astro-transition="persist">
  <div class="welcome-section">
    <h1 class="welcome-title">{t(lang, 'home.welcome')}</h1>
    <p class="welcome-description">{t(lang, 'home.description')}</p>
  </div>

  <section class="articles-section">
    <h2 class="section-title">{t(lang, 'home.latestArticles')}</h2>
    <div class="articles-grid">
      {latest.map(post => (
        <article class="article-card">
          <a href={post.url} class="article-link">
            <h3 class="article-title">{post.title}</h3>
            <time class="article-date" datetime={post.date.toISOString()}>
              {post.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-CN')}
            </time>
            {post.tags && (
              <div class="article-tags">
                <span class="tag">{post.tags}</span>
              </div>
            )}
          </a>
        </article>
      ))}
    </div>
  </section>

  {latestApps.length > 0 && (
    <section class="apps-section">
      <h2 class="section-title">{t(lang, 'home.apps')}</h2>
      <div class="apps-grid">
        {latestApps.map(app => (
          <a href={app.url} class="app-card">
            <div class="app-icon">🎮</div>
            <div class="app-info">
              <h3 class="app-title">{app.title}</h3>
              {app.description && <p class="app-desc">{app.description}</p>}
            </div>
            <span class="app-arrow">→</span>
          </a>
        ))}
      </div>
      <a href={`/${lang}/apps/`} class="view-all-link">{t(lang, 'home.viewAllApps')} →</a>
    </section>
  )}
</main>

<style>
  .home-content {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-2xl) 0;
  }

  .welcome-section {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
    padding: var(--spacing-3xl) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .welcome-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-xl) 0;
    line-height: var(--line-height-tight);
  }

  .welcome-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: var(--line-height-relaxed);
  }

  .articles-section {
    margin-top: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-2xl) 0;
    line-height: var(--line-height-tight);
  }

  .articles-grid {
    display: grid;
    gap: var(--spacing-xl);
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .article-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    transition: all var(--transition-normal);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-shadow);
  }

  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent-primary);
  }

  .article-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .article-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-md) 0;
    line-height: var(--line-height-tight);
  }

  .article-date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    display: block;
    margin-bottom: var(--spacing-md);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .tag {
    font-size: var(--font-size-xs);
    color: var(--color-accent-primary);
    background: var(--color-accent-light);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-medium);
  }

  .apps-section {
    margin-top: var(--spacing-4xl);
  }
  .apps-grid {
    display: grid;
    gap: var(--spacing-md);
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .app-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg) var(--spacing-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-normal);
    backdrop-filter: blur(var(--glass-blur));
    box-shadow: var(--glass-shadow);
  }
  .app-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: #ff9800;
  }
  .app-icon {
    font-size: 32px;
    flex-shrink: 0;
  }
  .app-info {
    flex: 1;
    min-width: 0;
  }
  .app-title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    margin: 0 0 4px 0;
    line-height: var(--line-height-tight);
  }
  .app-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .app-arrow {
    font-size: 20px;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .app-card:hover .app-arrow {
    transform: translateX(4px);
    color: #ff9800;
  }

  .view-all-link {
    display: block; text-align: center; margin-top: var(--spacing-xl);
    font-size: var(--font-size-sm); color: var(--color-accent-primary);
    text-decoration: none; letter-spacing: 1px;
    transition: all 0.3s;
  }
  .view-all-link:hover { color: var(--color-accent-hover); text-decoration: underline; }

  @media (max-width: 768px) {
    .home-content {
      padding: var(--spacing-xl) 0;
    }

    .welcome-title {
      font-size: var(--font-size-3xl);
    }

    .articles-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .article-card {
      padding: var(--spacing-lg);
    }
  }
</style>
