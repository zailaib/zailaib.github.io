---
// GamePage.astro  Reusable app entry page for all games
// Props:
//   game: string  game directory name
//   accentColor, accentBg, accentBorder, accentBgHover, accentBorderHover: CSS color values
//   frameBg: string  iframe wrapper background
//   frameMaxWidth?: number  default 1000
//   frameHeight: number  desktop iframe height in px
//   frameHeightMobile: number  mobile iframe height in px
//   content: { zh: {...}, en: {...} }  bilingual content
//   paper?: { zh: {...}, en: {...} }  optional further reading reference
import BaseLayout from '../layouts/BaseLayout.astro';

interface Paper {
  title: string; author: string; journal: string; year: string; doi: string; desc: string;
}

interface Props {
  game: string;
  accentColor: string;
  accentBg: string;
  accentBorder: string;
  accentBgHover: string;
  accentBorderHover: string;
  frameBg: string;
  frameMaxWidth?: number;
  frameHeight: number;
  frameHeightMobile: number;
  content: {
    zh: { title: string; subtitle: string; desc: string; play: string };
    en: { title: string; subtitle: string; desc: string; play: string };
  };
  paper?: { zh: Paper; en: Paper };
}

const {
  game,
  accentColor, accentBg, accentBorder, accentBgHover, accentBorderHover,
  frameBg, frameMaxWidth = 1000, frameHeight, frameHeightMobile,
  content,
  paper,
} = Astro.props;

const { lang } = Astro.params;
const c = content[lang as 'zh' | 'en'];
---

<BaseLayout title={c.title} currentSlug="" showMinimap={false}>
  <div class="game-page">
    <header class="game-header">
      <h1>{c.title}</h1>
      <p class="subtitle">{c.subtitle}</p>
      <p class="desc">{c.desc}</p>
      <a class="play-btn" href={`/games/${game}/`} target="_blank">{c.play}</a>
    </header>
    <div class="game-frame" style={`background:${frameBg};--fh:${frameHeight}px;--fhm:${frameHeightMobile}px`}>
      <iframe src={`/games/${game}/`} title={c.title} allowfullscreen scrolling="no"></iframe>
    </div>
    {
      paper && (
        <div class="paper-card">
          <h3>📚 {lang === 'zh' ? '延伸阅读' : 'Further Reading'}</h3>
          {paper[lang as 'zh' | 'en'].doi ? (
            <a href={`https://doi.org/${paper[lang as 'zh' | 'en'].doi}`} target="_blank" rel="noopener">
              <span class="paper-title">{paper[lang as 'zh' | 'en'].title}</span>
              <span class="paper-meta">{paper[lang as 'zh' | 'en'].author} ({paper[lang as 'zh' | 'en'].year}) · <em>{paper[lang as 'zh' | 'en'].journal}</em></span>
            </a>
          ) : (
            <div class="paper-info">
              <span class="paper-title">{paper[lang as 'zh' | 'en'].title}</span>
              <span class="paper-meta">{paper[lang as 'zh' | 'en'].author} ({paper[lang as 'zh' | 'en'].year}) · <em>{paper[lang as 'zh' | 'en'].journal}</em></span>
            </div>
          )}
          <p class="paper-desc">{paper[lang as 'zh' | 'en'].desc}</p>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .game-page {
    max-width: {frameMaxWidth}px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }
  .game-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .game-header h1 {
    font-size: var(--font-size-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
    letter-spacing: 2px;
  }
  .subtitle {
    font-size: var(--font-size-md);
    color: var(--color-text-tertiary);
    margin-bottom: var(--spacing-md);
  }
  .desc {
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--spacing-xl);
    line-height: var(--line-height-relaxed);
    font-size: 14px;
  }
  .play-btn {
    display: inline-block;
    padding: 12px 36px;
    background: {accentBg};
    color: {accentColor};
    text-decoration: none;
    border-radius: 2px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 2px;
    border: 1px solid {accentBorder};
    transition: all 0.3s;
  }
  .play-btn:hover {
    background: {accentBgHover};
    border-color: {accentBorderHover};
  }
  .game-frame {
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
  }
  .game-frame iframe {
    width: 100%;
    height: var(--fh);
    border: none;
    display: block;
  }

  @media (max-width: 768px) {
    .game-page { padding: var(--spacing-md); }
    .game-frame iframe { height: var(--fhm); }
    .paper-card { padding: 16px 18px; }
  }

  .paper-card {
    max-width: 640px; margin: var(--spacing-xl) auto 0;
    padding: 20px 24px;
    border-radius: 6px;
    border: 1px solid var(--color-border, rgba(255,255,255,0.06));
    background: var(--color-bg-elevated, rgba(255,255,255,0.02));
  }
  .paper-card h3 {
    font-size: 13px; color: var(--color-text-tertiary);
    margin-bottom: 12px; letter-spacing: 1px; font-weight: 600;
  }
  .paper-card a, .paper-info {
    display: flex; flex-direction: column; gap: 4px;
    text-decoration: none; color: inherit;
  }
  .paper-card a { transition: opacity 0.2s; }
  .paper-card a:hover { opacity: 0.7; }
  .paper-title {
    font-size: 15px; font-weight: 600; color: {accentColor};
    line-height: 1.4;
  }
  .paper-meta {
    font-size: 12px; color: var(--color-text-tertiary);
  }
  .paper-desc {
    font-size: 13px; color: var(--color-text-secondary);
    margin-top: 10px; line-height: var(--line-height-relaxed);
  }
</style>
